{
  "name": "battle-tanks-royale",
  "version": "11.0.0",
  "description": "🎮 Battle Tanks Royale - Ultimate Battle Royale Game Server",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "cluster": "NODE_ENV=production node server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write .",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js",
    "db:reset": "node scripts/reset.js",
    "logs": "tail -f logs/combined.log",
    "logs:error": "tail -f logs/error.log",
    "logs:audit": "tail -f logs/audit.log",
    "logs:performance": "tail -f logs/performance.log",
    "monitor": "node scripts/monitor.js",
    "backup": "node scripts/backup.js",
    "restore": "node scripts/restore.js",
    "clean": "rm -rf logs/*.log && rm -rf node_modules/.cache",
    "postinstall": "node scripts/postinstall.js"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "helmet": "^7.0.0",
    "http-status-codes": "^2.2.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.11.3",
    "redis": "^4.6.7",
    "socket.io": "^4.7.2",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "eslint": "^8.51.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-node": "^11.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.0.3",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/logs/",
      "/scripts/"
    ],
    "collectCoverageFrom": [
      "*.js",
      "!server.js"
    ]
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es2021": true,
      "jest": true
    },
    "extends": [
      "eslint:recommended",
      "plugin:node/recommended",
      "prettier"
    ],
    "parserOptions": {
      "ecmaVersion": 2021,
      "sourceType": "module"
    },
    "rules": {
      "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
      "no-console": ["warn", { "allow": ["warn", "error", "info"] }],
      "node/no-unpublished-require": "off"
    }
  },
  "prettier": {
    "singleQuote": true,
    "trailingComma": "es5",
    "tabWidth": 2,
    "semi": true,
    "printWidth": 100,
    "bracketSpacing": true,
    "arrowParens": "always"
  },
  "nodemonConfig": {
    "ignore": [
      "logs/*",
      "node_modules/*",
      "*.test.js"
    ],
    "watch": [
      "server.js",
      "src/"
    ],
    "ext": "js,json",
    "delay": 1000
  },
  "keywords": [
    "game",
    "battle-royale",
    "tanks",
    "multiplayer",
    "websocket",
    "real-time",
    "threejs",
    "gaming",
    "mmo"
  ],
  "author": "Battle Tanks Royale Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/battle-tanks-royale.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/battle-tanks-royale/issues"
  },
  "homepage": "https://github.com/yourusername/battle-tanks-royale#readme"
}
